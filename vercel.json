{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1.js" },
    { "src": "/painel-lider", "dest": "/painel-lider.html" },
    { "src": "/", "dest": "/prep-at-home.html" }
  ]
}
